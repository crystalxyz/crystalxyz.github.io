---
import MetaPage from "@/components/MetaPage.astro"
import ProjectCard from "@/components/ProjectCard.astro"
import Layout from "@/layouts/Layout.astro"
import { getCollection } from "astro:content"

const projects = (await getCollection("projects")).sort((a, b) => {
  // Explicit `order` pins a project (lower = higher); the rest fall back to
  // most-recent start date.
  const ao = a.data.order ?? Infinity
  const bo = b.data.order ?? Infinity
  if (ao !== bo) return ao - bo
  return (b.data.startDate?.getTime() ?? 0) - (a.data.startDate?.getTime() ?? 0)
})
---

<Layout>
  <MetaPage slot="head" title="Projects" />
  <ul>
    {projects.map((project) => <ProjectCard project={project} />)}
  </ul>
</Layout>

<style>
  ul {
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
  }
</style>
